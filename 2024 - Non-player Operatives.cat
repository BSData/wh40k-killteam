        <profile name="Aggressive Defence Construct" typeId="f887-5881-0e6d-755c" typeName="Abilities" hidden="false" id="b492-e6cf-9a28-44ee">
          <characteristics>
            <characteristic name="Ability" typeId="3467-0678-083e-eb50">If this operative is incapacitated by an enemy operative within 2&quot; of it, roll one D3; on a 2+, inflict damage on that enemy operative equal to the result.</characteristic>
          </characteristics>
        </profile>
      </profiles>
