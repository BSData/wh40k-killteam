            <characteristic name="Move" typeId="c996-ffb3-e0b4-ecfa">6&quot;</characteristic>
            <characteristic name="Save" typeId="3241-5548-12d6-f103">3+</characteristic>
            <characteristic name="Wounds" typeId="74f9-f91c-b8fd-89d9">15</characteristic>
          </characteristics>
        </profile>
        <profile name="Multi-Threat Eliminator" typeId="f887-5881-0e6d-755c" typeName="Abilities" hidden="false" id="3432-ed65-fe39-5f38">
          <characteristics>
            <characteristic name="Ability" typeId="3467-0678-083e-eb50">Whenever a player operative within 8&quot; of this NPO is shooting it, keep track of each attack dice that&apos;s discarded as a fail. After the action, before incapacitated operatives are removed (including this one, if relevant), this NPO can perform a free **Shoot** action (you can change its order to Engage to do so), but it can only target that player operative with its enmitic disintegrator pistols (focused), and you only roll a number of attack dice equal to the opponent&apos;s discarded attack dice plus one (to a maximum of four).</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink name="Operative" hidden="false" id="c75a-7a19-160c-d627" targetId="cf83-4496-b58e-ac82" primary="true"/>
