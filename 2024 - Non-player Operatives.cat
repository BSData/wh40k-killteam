                          <characteristics>
                            <characteristic name="Ability" typeId="3467-0678-083e-eb50">When this operative finishes moving during the Charge action, inflict D3+3 damage on one enemy operative within its control range.</characteristic>
                          </characteristics>
                        </profile>
                      </profiles>
