        <profile name="Weapons Team" typeId="f887-5881-0e6d-755c" typeName="Abilities" hidden="false" id="e393-fd34-210f-67dd">
          <characteristics>
            <characteristic name="Ability" typeId="3467-0678-083e-eb50">Whenever this operative is activated, if a friendly LOADER operative is within its control range, all profiles of its missile launcher have the Heavy (**Dash** only) weapon rule instead of the Heavy weapon rule until the end of that activation.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="dc18-ae36-df77-3ca0" shared="true" id="c7f8-a11c-fcde-8842"/>
